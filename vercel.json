{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/portfolio/index.test.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/artifacts/portfolio/index.test.html"
    },
    {
      "src": "/(.*)",
      "dest": "/artifacts/portfolio/$1"
    }
  ]
}
